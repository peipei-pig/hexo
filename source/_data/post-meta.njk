{# source/_data/post-meta.njk #}
{% if is_index and post %}
  {% set plain_text = post.content | striptags %}
  <span class="post-meta-item post-meta-reading" data-reading-symbols="{{ plain_text | length }}">
    <span class="post-meta-item-icon"><i class="far fa-clock"></i></span>
    <span class="post-meta-item-text">阅读约</span>
    <span class="post-reading-time-value">1 分钟</span>
  </span>

  {% if post.tags and post.tags.length %}
    <span class="post-meta-item post-meta-tags-lite">
      <span class="post-meta-item-icon"><i class="fa fa-tags"></i></span>
      {% for tag in post.tags.toArray().slice(0, 2) %}
        <a class="post-tag-link-lite" href="{{ url_for(tag.path) }}" rel="tag">{{ tag.name }}</a>
      {% endfor %}
    </span>
  {% endif %}
{% endif %}

{% if page.layout == 'post' %}
  <span class="post-meta-item">
    <span class="post-meta-item-icon"><i class="fa fa-eye"></i></span>
    <span class="post-meta-item-text">Views:</span>
    <span id="vercount_value_page_pv">0</span>
  </span>
{% endif %}
